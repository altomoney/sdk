{
  "name": "@altomoney/sdk",
  "version": "0.1.5",
  "description": "Framework-agnostic Alto protocol entity SDK.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "AGENTS.md",
    "agent-reference.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/altomoney/sdk",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bunx tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun x vitest run",
    "publish:dry-run": "npm publish --dry-run --access public"
  }
}
